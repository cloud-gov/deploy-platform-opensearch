notifications:
    channels:
    - description: Critical security alerts for OpenSearch cluster
      enabled: true
      message: A security event has been detected in the OpenSearch cluster.
      name: security-alerits
      sender_name: platform_ses
      subject: OpenSearch Security Alert
      type: email
      users:
      - jason.gambino@gsa.gov
      - jason.gambino@pif.gov
    - description: Performance monitoring alerts
      enabled: true
      message: Performance threshold exceeded in OpenSearch cluster.
      name: platform_test
      sender_name: platform_ses
      subject: OpenSearch Performance Alert
      type: email
      users:
      - jason.gambino@gsa.gov
      - test-user-rocks@gsa.gov
    email_accounts:
    - from_address: no-reply@platform-alerts.dev.us-gov-west-1.aws-us-gov.cloud.gov
      name: platform_ses
      smtp_host: email-smtp.us-gov-west-1.amazonaws.com
      smtp_method: ssl
      smtp_port: 2465
    secrets_prefix: ((opensearch-notifications-secrets-prefix))